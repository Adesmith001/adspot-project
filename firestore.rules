rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userRole() {
      return signedIn() ? userDoc().data.role : null;
    }

    function isAdmin() {
      return signedIn() && userRole() == "admin";
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow create: if signedIn() && request.auth.uid == userId;
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow update: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /listings/{listingId} {
      allow read: if resource.data.approvalStatus == "approved" || isAdmin() || (signedIn() && request.auth.uid == resource.data.ownerId);
      allow create: if signedIn() && request.auth.uid == request.resource.data.ownerId;
      allow update, delete: if isAdmin() || (signedIn() && request.auth.uid == resource.data.ownerId);
    }

    match /bookings/{bookingId} {
      allow create: if signedIn() && request.auth.uid == request.resource.data.advertiserId;
      allow read: if isAdmin() || (signedIn() && (
        request.auth.uid == resource.data.advertiserId ||
        request.auth.uid == resource.data.ownerId
      ));
      allow update: if isAdmin() || (signedIn() && (
        request.auth.uid == resource.data.advertiserId ||
        request.auth.uid == resource.data.ownerId
      ));
      allow delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow create: if signedIn();
      allow read: if isAdmin() || (signedIn() && request.auth.uid == resource.data.userId);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
